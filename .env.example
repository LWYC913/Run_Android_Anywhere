# Local development only. Replace every credential before deploying.
API_BIND_ADDR=127.0.0.1:8080
METRICS_BIND_ADDR=127.0.0.1:9090

DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/run_anywhere_dev
RUN_MIGRATIONS=true
BOOTSTRAP_ADMIN_TOKEN=replace-with-a-long-local-admin-token

NATS_URL=nats://127.0.0.1:4222

S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=run-anywhere
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Generate this local-only Ed25519 key with `just dev-jwt-key`.
JWT_SIGNING_KEY_FILE=.local/debug-jwt-private.pem
JWT_KID=raa-debug-local-v1
DEBUG_TOKEN_TTL_SECONDS=900
DEBUG_GATEWAY_BASE_URL=http://127.0.0.1:8081

REQUEST_TIMEOUT_SECONDS=30
MAX_JSON_BODY_BYTES=1048576
WEBHOOK_ALLOW_PRIVATE_NETWORKS=false

# Leave blank to disable OTLP export during local development.
OTEL_EXPORTER_OTLP_ENDPOINT=
RUST_LOG=run_anywhere_api=info,tower_http=info
